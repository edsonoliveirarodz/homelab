# Copy this file to terraform.tfvars and fill in your values.
# cp terraform.tfvars.example terraform.tfvars
#
# Proxmox credentials — same values as terraform/terraform.tfvars.

proxmox_endpoint     = "https://192.168.1.100:8006"
proxmox_ssh_username = "root"
proxmox_node         = "proxmox"
proxmox_node_address = "192.168.1.100"
proxmox_api_token    = "terraform@pve!terraform=00000000-0000-0000-0000-000000000000"

network_gateway  = "192.168.1.1"
network_bridge   = "vmbr0"
template_id      = 1000
snippets_storage = "local"
disk_storage     = "local-lvm"
ssh_public_key   = "ssh-rsa AAAA...your-public-key... user@host"

# VM configuration
vm = {
  name            = "test-vm"
  vm_id           = 200
  ip              = "192.168.1.210/24"
  cores           = 2
  memory          = 2048
  disk_size       = 20
  bios            = "ovmf"
  scsi_hardware   = "virtio-scsi-single"
  stop_on_destroy = true
  tags            = ["vm"]
}
